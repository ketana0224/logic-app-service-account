# ============================================================================
# Environment Configuration Template
# ============================================================================
# このファイルは環境変数の例です。
# 実際に使用する場合は .env.local にコピーしてカスタマイズしてください。
#
# 使用方法:
#   PowerShell: . ./setup-env.ps1 (対話形式で設定)
#   または
#   手動: このファイルをコピーして値を設定
# ============================================================================

# ============================================================================
# Phase 0: Azure & Microsoft 365 基本情報
# ============================================================================

# Azure subscription ID
# 取得方法: az account list
AZURE_SUBSCRIPTION_ID="<YOUR-AZURE-SUBSCRIPTION-ID>"

# Azure Tenant ID (Logic App リソースをホストするテナント)
# 取得方法: az account show --query tenantId
AZURE_TENANT_ID="<YOUR-AZURE-TENANT-ID>"

# Microsoft 365 Tenant ID (Teams チャットを送信するテナント)
# 取得方法: M365 管理画ーターから組織プロファイル > 組織 ID
M365_TENANT_ID="<YOUR-M365-TENANT-ID>"

# Service Account UPN (Teams 通知用)
# 形式: system-notify@<your-m365-tenant>.onmicrosoft.com
SERVICE_ACCOUNT_UPN="system-notify@<your-m365-tenant>.onmicrosoft.com"

# ============================================================================
# Phase 1: インフラストラクチャ設定
# ============================================================================

# Resource Group 名
RESOURCE_GROUP_NAME="rg-sendmsg-app"

# Azure リージョン
# 利用可能: westus2, japaneast, eastus2
# ※ Linux WS1 は westus2 で利用不可 (Windows WS1 のみ)
LOCATION="eastus2"

# Logic App Standard リソース名 (参考: la-<workload>-<purpose>)
LOGIC_APP_NAME="la-sendmsg-m365-connector"

# Key Vault リソース名 (参考: kv-<workload>-001, グローバル一意)
KEY_VAULT_NAME="kv-sendmsg-001"

# Storage Account 名 (参考: st<workload>001, 英小文字/数字のみ 3-24)
STORAGE_ACCOUNT_NAME="stsendmsg001"

# App Service Plan 名 (参考: asp-<workload>-workflow)
APP_SERVICE_PLAN_NAME="asp-sendmsg-workflow"

# Storage Account 名 (自動採番される場合はスキップ可能)
# STORAGE_ACCOUNT_NAME="stsendmsg001"

# ============================================================================
# Phase 1: ネットワーク設定
# ============================================================================

# VNet 名 (参考: vnet-<workload>)
VNET_NAME="vnet-sendmsg"

# VNet アドレス範囲
VNET_ADDRESS_PREFIX="10.0.0.0/16"

# Logic App サブネット CIDR
SUBNET_LOGICAPP_PREFIX="10.0.1.0/27"

# Private Endpoint サブネット CIDR
SUBNET_PEP_PREFIX="10.0.2.0/27"

# Azure Firewall サブネット CIDR
SUBNET_FIREWALL_PREFIX="10.0.3.0/26"

# Jumpbox サブネット CIDR
SUBNET_JUMPBOX_PREFIX="10.0.4.0/27"

# Azure Firewall リソース名 (参考: afw-<workload>)
FIREWALL_NAME="afw-sendmsg"

# Azure Firewall Policy リソース名 (参考: afwp-<workload>)
FIREWALL_POLICY_NAME="afwp-sendmsg"

# ============================================================================
# Phase 2: Entra ID アプリ登録情報
# ============================================================================

# Entra App Registration Client ID
# ※ Phase 2 でアプリ登録完了後に値を入力してください
# 取得方法: Azure Portal > Entra ID > アプリ登録 > 概要 > アプリケーション (クライアント) ID
ENTRA_APP_CLIENT_ID="<YOUR-ENTRA-APP-CLIENT-ID>"

# Entra App Registration Client Secret (optional - 通常は不要)
# ENTRA_APP_CLIENT_SECRET="<YOUR-CLIENT-SECRET>"

# ============================================================================
# Phase 3: OAuth Bootstrap 設定
# ============================================================================

# HTTP リダイレクト URI ポート (通常は変更不要)
REDIRECT_URI_PORT="8400"

# OAuth スコープ (通常は変更不要)
# OAUTH_SCOPES="https://graph.microsoft.com/.default offline_access"

# ============================================================================
# Phase 4: 監視・ログ設定
# ============================================================================

# Log Analytics ワークスペース名 (参考: log-<workload>)
LOG_ANALYTICS_NAME="log-sendmsg"

# Application Insights リソース名 (参考: appi-<workload>)
APP_INSIGHTS_NAME="appi-sendmsg"

# ============================================================================
# オプション: デプロイメント設定
# ============================================================================

# デプロイメント検証 (what-if) 実行フラグ
# SKIP_VALIDATION="false"

# 自動デプロイメント開始フラグ
# AUTO_DEPLOY="false"

# ============================================================================
# リソースタグ
# ============================================================================

# タグ: ワークロード
TAG_WORKLOAD="logic-app-service-account"

# タグ: 環境 (dev, test, prod)
TAG_ENVIRONMENT="dev"

# タグ: オーナー
TAG_OWNER="<YOUR-EMAIL>"

# タグ: コスト センター (オプション)
TAG_COST_CENTER="<YOUR-COST-CENTER>"
